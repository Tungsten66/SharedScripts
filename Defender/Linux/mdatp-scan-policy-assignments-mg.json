{
  "$schema": "https://schema.management.azure.com/schemas/2019-08-01/managementGroupDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "definitionManagementGroupId": {
      "type": "string",
      "metadata": {
        "description": "Management group ID where the policy definitions were created (by mdatp-scan-policy-definitions.json)."
      }
    },
    "assignmentManagementGroupId": {
      "type": "string",
      "defaultValue": "[managementGroup().name]",
      "metadata": {
        "description": "Management group ID to assign the policies to. Defaults to the management group targeted by this deployment."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Location for the policy assignment managed identities. Use the primary region of the target machines (e.g., usgovvirginia)."
      }
    }
  },
  "variables": {
    "arcPolicyName": "deploy-mdatp-scan-arc-linux",
    "vmPolicyName": "deploy-mdatp-scan-vm-linux",
    "arcAssignmentName": "deploy-mdatp-cron-arc",
    "vmAssignmentName": "deploy-mdatp-cron-vm",
    "assignmentScope": "[concat('/providers/Microsoft.Management/managementGroups/', parameters('assignmentManagementGroupId'))]",
    "arcPolicyDefinitionId": "[extensionResourceId(tenantResourceId('Microsoft.Management/managementGroups', parameters('definitionManagementGroupId')), 'Microsoft.Authorization/policyDefinitions', variables('arcPolicyName'))]",
    "vmPolicyDefinitionId": "[extensionResourceId(tenantResourceId('Microsoft.Management/managementGroups', parameters('definitionManagementGroupId')), 'Microsoft.Authorization/policyDefinitions', variables('vmPolicyName'))]",
    "arcRoleDefinitionId": "/providers/Microsoft.Authorization/roleDefinitions/cd570a14-e51a-42ad-bac8-bafd67325302",
    "vmRoleDefinitionId": "/providers/Microsoft.Authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
  },
  "resources": [
    {
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2024-04-01",
      "name": "[variables('arcAssignmentName')]",
      "location": "[parameters('location')]",
      "scope": "[variables('assignmentScope')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "displayName": "Deploy: MDATP Weekly Scan Cron — Arc Linux",
        "description": "Deploys the MDATP weekly quick scan cron entry to Arc-connected Linux machines via Run Command.",
        "policyDefinitionId": "[variables('arcPolicyDefinitionId')]",
        "scope": "[variables('assignmentScope')]"
      }
    },
    {
      "type": "Microsoft.Authorization/policyAssignments",
      "apiVersion": "2024-04-01",
      "name": "[variables('vmAssignmentName')]",
      "location": "[parameters('location')]",
      "scope": "[variables('assignmentScope')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "displayName": "Deploy: MDATP Weekly Scan Cron — Azure VM Linux",
        "description": "Deploys the MDATP weekly quick scan cron entry to Azure Linux VMs via Run Command.",
        "policyDefinitionId": "[variables('vmPolicyDefinitionId')]",
        "scope": "[variables('assignmentScope')]"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('arcAssignmentName'), variables('arcRoleDefinitionId'), variables('assignmentScope'))]",
      "scope": "[variables('assignmentScope')]",
      "dependsOn": [
        "[variables('arcAssignmentName')]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('arcRoleDefinitionId')]",
        "principalId": "[reference(extensionResourceId(variables('assignmentScope'), 'Microsoft.Authorization/policyAssignments', variables('arcAssignmentName')), '2024-04-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(variables('vmAssignmentName'), variables('vmRoleDefinitionId'), variables('assignmentScope'))]",
      "scope": "[variables('assignmentScope')]",
      "dependsOn": [
        "[variables('vmAssignmentName')]"
      ],
      "properties": {
        "roleDefinitionId": "[variables('vmRoleDefinitionId')]",
        "principalId": "[reference(extensionResourceId(variables('assignmentScope'), 'Microsoft.Authorization/policyAssignments', variables('vmAssignmentName')), '2024-04-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      }
    }
  ],
  "outputs": {
    "arcAssignmentPrincipalId": {
      "type": "string",
      "value": "[reference(extensionResourceId(variables('assignmentScope'), 'Microsoft.Authorization/policyAssignments', variables('arcAssignmentName')), '2024-04-01', 'full').identity.principalId]"
    },
    "vmAssignmentPrincipalId": {
      "type": "string",
      "value": "[reference(extensionResourceId(variables('assignmentScope'), 'Microsoft.Authorization/policyAssignments', variables('vmAssignmentName')), '2024-04-01', 'full').identity.principalId]"
    }
  }
}
